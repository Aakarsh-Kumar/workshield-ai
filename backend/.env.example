# Copy this to .env and fill in secret values before running locally
MONGO_URI=mongodb://mongo:27017/workshield
JWT_SECRET=f4ed4149bdcef6a1baf0b8fac50ca745613f0cdf808d85fa9bb281ef5e69efa7
JWT_EXPIRES_IN=7d
PORT=4000
AI_SERVICE_URL=http://ai-service:5001
CLIENT_URL=http://localhost

# Rate limiting
DISABLE_RATE_LIMIT=false
RATE_LIMIT_API_MAX=400
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_CLAIM_WRITE_MAX=90
RATE_LIMIT_TEAM2_MAX=180

# Weather integration for rainfall trigger auto-observation
# WEATHER_API_MODE=live uses Open-Meteo providers
# WEATHER_API_MODE=mock uses deterministic generated rainfall values for testing/offline mode
WEATHER_API_MODE=live
WEATHER_API_TIMEOUT_MS=7000
WEATHER_ARCHIVE_ENDPOINT=https://archive-api.open-meteo.com/v1/archive
WEATHER_FORECAST_ENDPOINT=https://api.open-meteo.com/v1/forecast
